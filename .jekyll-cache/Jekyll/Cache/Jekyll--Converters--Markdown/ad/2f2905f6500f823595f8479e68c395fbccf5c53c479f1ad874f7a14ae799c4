	<span class="n">x_support_low_dim</span> <span class="o">=</span> <span class="n">x_low_dim</span><span class="p">[</span><span class="n">support_ind</span><span class="p">]</span>

	<span class="k">for</span> <span class="n">ind</span> <span class="ow">in</span> <span class="nb">range</span><span class="p">(</span><span class="n">x</span><span class="o">.</span><span class="n">shape</span><span class="p">[</span><span class="mi">0</span><span class="p">]):</span>
