</span>				<span class="k">if</span> <span class="nb">abs</span><span class="p">(</span> <span class="n">new_objective_func</span> <span class="o">-</span> <span class="bp">self</span><span class="o">.</span><span class="n">objective_func</span> <span class="p">)</span> <span class="o">&lt;=</span> <span class="n">epsilon</span><span class="p">:</span>
